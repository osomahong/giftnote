{
  "$schema": "event-schema",
  "version": "2.0.0",
  "ga4MeasurementId": "G-RBMBJ6VD54",
  "gtmContainerId": "GTM-WVTWX2K5",
  "events": [
    {
      "name": "collection_card_click",
      "trigger": "컬렉션 카드 클릭",
      "parameters": {
        "section": { "type": "string", "custom": true, "example": "최신 큐레이션 (고정)" },
        "index": { "type": "number", "custom": true, "example": "1 (순서값 없을 시 제외)" },
        "content_type": { "type": "string", "custom": true, "example": "collection (고정)" },
        "content_title": { "type": "string", "custom": true, "example": "운동하는 남자친구 생일 선물 추천 3만원대" },
        "content_id": { "type": "string", "custom": true, "example": "fitness-boyfriend-30k-birthday" },
        "content_url": { "type": "string", "custom": true, "example": "/collection/fitness-boyfriend-30k-birthday/" }
      },
      "selector": "[data-track='collection-card']"
    },
    {
      "name": "purchase_click",
      "trigger": "구매 버튼 클릭",
      "parameters": {
        "item_name": { "type": "string", "custom": true },
        "item_brand": { "type": "string", "custom": true },
        "price": { "type": "number", "custom": true },
        "platform": { "type": "string", "custom": true, "example": "coupang" },
        "content_id": { "type": "string", "custom": true, "example": "fitness-boyfriend-30k-birthday" }
      },
      "selector": "[data-track='purchase-btn']"
    },
    {
      "name": "faq_open",
      "trigger": "FAQ 열기",
      "parameters": {
        "content_title": { "type": "string", "custom": true, "example": "운동하는 남자친구 생일선물 3만원대로 뭐가 좋을까요?" },
        "content_id": { "type": "string", "custom": true, "example": "fitness-boyfriend-30k-birthday" }
      },
      "selector": "[data-track='faq-item']"
    },
    {
      "name": "tag_click",
      "trigger": "태그 클릭",
      "parameters": {
        "menu_type": { "type": "string", "custom": true, "example": "태그 (고정)" },
        "menu_title": { "type": "string", "custom": true, "example": "생일" }
      },
      "selector": "[data-track='tag-link']"
    },
    {
      "name": "related_click",
      "trigger": "관련 큐레이션 클릭",
      "parameters": {
        "section": { "type": "string", "custom": true, "example": "또 이런 선물 추천 리스트도 있어요 (고정)" },
        "content_type": { "type": "string", "custom": true, "example": "related_collection (고정)" },
        "content_title": { "type": "string", "custom": true, "example": "여자친구 생일 감성 선물 추천 2만원대" },
        "content_id": { "type": "string", "custom": true, "example": "sentimental-girlfriend-20k-birthday" }
      },
      "selector": "[data-track='related-card']"
    },
    {
      "name": "menu_click",
      "trigger": "상단 메뉴 클릭",
      "parameters": {
        "menu_type": { "type": "string", "custom": true, "example": "상단 태그 네비 (고정)" },
        "menu_title": { "type": "string", "custom": true, "example": "#생일" }
      },
      "selector": "[data-track='nav-tag']"
    }
  ],
  "customDimensions": [
    { "name": "section", "scope": "EVENT", "description": "section" },
    { "name": "content_type", "scope": "EVENT", "description": "content type" },
    { "name": "content_title", "scope": "EVENT", "description": "content title" },
    { "name": "content_id", "scope": "EVENT", "description": "content id" },
    { "name": "content_url", "scope": "EVENT", "description": "content url" },
    { "name": "platform", "scope": "EVENT", "description": "platform" },
    { "name": "menu_type", "scope": "EVENT", "description": "menu type" },
    { "name": "menu_title", "scope": "EVENT", "description": "menu title" },
    { "name": "index", "scope": "EVENT", "description": "index" },
    { "name": "item_name", "scope": "EVENT", "description": "item name" },
    { "name": "item_brand", "scope": "EVENT", "description": "item brand" }
  ],
  "conversionEvents": [
    "purchase_click"
  ]
}
